# =============================================
# إعدادات منصة الإمام مالك التعليمية
# انسخ هذا الملف إلى .env واملأ القيم الحقيقية
# =============================================

# توكن البوت من BotFather
BOT_TOKEN=your_bot_token_here

# قائمة معرفات المشرفين (أرقام تيليجرام) مفصولة بفواصل
# مثال: 123456789,987654321
ADMIN_IDS=admin_id_1,admin_id_2

# مسار قاعدة البيانات (SQLite للتطوير)
DATABASE_URL=sqlite:///./imam_malik.db

# وضع التصحيح (True للتطوير، False للإنتاج)
DEBUG=True

# الرابط العام للخادم (عند النشر)
# WEBHOOK_URL=https://your-domain.com
